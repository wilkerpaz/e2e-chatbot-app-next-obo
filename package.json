{
  "name": "@databricks/e2e-chatbot-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "packages/*"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --workspace=@databricks/chatbot-server",
    "dev:client": "npm run dev --workspace=@databricks/chatbot-client",
    "build": "npm run db:migrate && npm run build:client && npm run build:server",
    "build:client": "npm run build --workspace=@databricks/chatbot-client",
    "build:server": "npm run build --workspace=@databricks/chatbot-server",
    "start": "npm run start --workspace=@databricks/chatbot-server",
    "lint": "biome lint --write --unsafe",
    "lint:fix": "biome lint --write --unsafe && biome format --write",
    "format": "biome format --write",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:reset": "tsx scripts/reset-database.ts",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:check": "drizzle-kit check",
    "db:up": "drizzle-kit up",
    "test": "npm run test:with-db && npm run test:ephemeral",
    "test:with-db": "PLAYWRIGHT=True TEST_MODE=with-db npx playwright test",
    "test:ephemeral": "PLAYWRIGHT=True TEST_MODE=ephemeral npx playwright test"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.44.6",
    "obug": "^2.1.1",
    "tsx": "^4.19.1",
    "unrun": "^0.2.32"
  },
  "devDependencies": {
    "@ai-sdk/provider": "^3.0.5",
    "@biomejs/biome": "1.9.4",
    "@playwright/test": "^1.50.1",
    "@types/babel__core": "^7.20.5",
    "@types/babel__generator": "^7.6.8",
    "@types/babel__template": "^7.4.4",
    "@types/babel__traverse": "^7.20.5",
    "@types/body-parser": "^1.19.5",
    "@types/connect": "^3.4.38",
    "@types/cors": "^2.8.17",
    "@types/d3": "^7.4.3",
    "@types/debug": "^4.1.12",
    "@types/express": "^4.17.21",
    "@types/hast": "^3.0.4",
    "@types/http-errors": "^2.0.4",
    "@types/katex": "^0.16.7",
    "@types/mdast": "^4.0.3",
    "@types/ms": "^0.7.34",
    "@types/node": "^22.8.6",
    "@types/prismjs": "^1.26.4",
    "@types/prop-types": "^15.7.12",
    "@types/qs": "^6.9.15",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/serve-static": "^1.15.7",
    "@types/statuses": "^2.0.5",
    "concurrently": "^8.2.2",
    "msw": "^2.11.6",
    "tsdown": "0.15.9",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "esbuild": ">=0.25.0"
  }
}
